{
    "algo_name": "act",
    "experiment": {
        "name": "act_tool_hang",
        "validate": true,
        "logging": {
            "terminal_output_to_txt": true,
            "log_tb": true
        }
    },
    "train": {
        "data": "path/to/your/tool_hang.hdf5",
        "seq_length": 100,
        "batch_size": 16,
        "num_epochs": 2000
    },
    "algo": {
        "chunk_size": 100,
        "kl_weight": 10.0,
        "exp_decay_k": 0.01
    },
    "observation": {
        "modalities": {
            "obs": {
                "low_dim": [
                    "robot0_eef_pos",
                    "robot0_eef_quat",
                    "robot0_gripper_qpos"
                ],
                "rgb": [
                    "agentview_image",
                    "robot0_eye_in_hand_image"
                ]
            }
        }
    }
}